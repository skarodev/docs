{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Skaro",
  "colors": {
    "primary": "#589df6",
    "light": "#f2f2f2",
    "dark": "#262626"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/skarodev/skaro"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "getting-started/introduction",
              "getting-started/installation",
              "getting-started/quickstart",
              "getting-started/core-concepts"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/init",
              "cli/config",
              "cli/skaro-update"
            ]
          },
          {
            "group": "Web Dashboard",
            "pages": [
              "dashboard/overview"
            ]
          },
          {
            "group": "LLM Providers",
            "pages": [
              "providers/supported-providers"
            ]
          },
          {
            "group": "Project Structure",
            "pages": [
              "project-structure/skaro-directory"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/new-project"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/skarodev/skaro"
    }
  }
}
